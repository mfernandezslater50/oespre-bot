# Copia este archivo como .env y completa los valores.
# NUNCA subas el archivo .env a un repositorio público.

# Tu clave de Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Secreto compartido entre la app OESPRE y este proxy.
# Genera uno aleatorio (ej: openssl rand -hex 24) y ponlo también en el servidor de OESPRE.
OESPRE_ASSISTANT_TOKEN=cambia-esto-por-un-secreto-largo

# Puerto (opcional)
PORT=8787
